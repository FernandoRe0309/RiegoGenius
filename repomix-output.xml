            <p className="mt-1 text-xs leading-relaxed text-muted-foreground">
              {prediction.recommendation}
            </p>

            {/* Factors */}
            <div className="mt-3 flex flex-col gap-1">
              {prediction.factors.sensor_factors.slice(0, 2).map((f, i) => (
